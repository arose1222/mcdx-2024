<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Future_Assignment_Date</fullName>
    <active>true</active>
    <description>Territory Assignment Date cannot be in the future</description>
    <errorConditionFormula>Territory_Assignment_Date__c &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Territory_Assignment_Date__c</errorDisplayField>
    <errorMessage>Territory Assignment Date cannot be in the future</errorMessage>
</ValidationRule>
