<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Dissolution_Rate_Range_Validation</fullName>
    <active>true</active>
    <description>Ensure Dissolution Rate is between 1 and 10 when populated</description>
    <errorConditionFormula>AND(NOT(ISBLANK(Dissolution_Rate__c)), OR(Dissolution_Rate__c &lt; 1, Dissolution_Rate__c &gt; 10))</errorConditionFormula>
    <errorDisplayField>Dissolution_Rate__c</errorDisplayField>
    <errorMessage>Dissolution Rate must be between 1 and 10</errorMessage>
</ValidationRule>
